# 프론트엔드 URL (끝에 슬래시 없이, CORS 허용 출처)
# 로컬 개발: http://localhost:5173
# 프로덕션: https://your-frontend.vercel.app
# 여러 개: https://a.vercel.app,https://custom-domain.com
FRONTEND_URL=http://localhost:5173

# GitHub OAuth App 설정
# GitHub Settings > Developer settings > OAuth Apps에서 발급
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# JWT 서명 키 (최소 32자 이상 랜덤 문자열)
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_min_32_chars

# 하네스 랩 로그 디렉토리
HARNESS_LAB_DIR=../.harness-lab
