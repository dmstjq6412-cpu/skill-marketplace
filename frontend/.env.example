# 백엔드 URL (끝에 슬래시 없이)
# 로컬 개발: http://localhost:3001
# 프로덕션(Render): https://your-backend-name.onrender.com
VITE_API_URL=https://your-backend-name.onrender.com

# GitHub OAuth App Client ID (backend와 동일한 값)
# GitHub Settings > Developer settings > OAuth Apps에서 확인
VITE_GITHUB_CLIENT_ID=your_github_client_id
